# =============================================
#  TECHYBOX BACKEND — Environment Variables
#  Copy this file to .env and fill in values
# =============================================

# --- SMTP / Gmail Settings ---
# Use a Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=techybox26@gmail.com
SMTP_PASS=your_gmail_app_password_here

# --- Email Routing ---
# Who receives the quote requests
RECIPIENT_EMAIL=techybox26@gmail.com
# Who appears as the sender
FROM_NAME=Techy Box Website

# --- Server ---
PORT=3001

# --- CORS (set to your website's domain in production) ---
# For local dev, use * or http://127.0.0.1:5500
ALLOWED_ORIGIN=*
